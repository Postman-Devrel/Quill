# Required secrets — set these via `ast project configure` before `ast project start`.
# Local development reads these from a .env file at the Quill/ root.

# Anthropic — auto-injected by the platform when astropods.yml declares
# `models.anthropic.provider: anthropic`. For local-only smoke tests you can
# set it directly here.
ANTHROPIC_API_KEY=

# Tavily — web research for the write_draft tool
TAVILY_API_KEY=

# WordPress — blog.postman.com REST API auth (Application Password)
WP_USERNAME=
WP_APP_PASSWORD=

# Confluence — a single service-account identity + shared destination space.
# All Quill blog drafts get saved to CONFLUENCE_SPACE_KEY under the identity
# of CONFLUENCE_EMAIL (should be a bot account like quill@postman.com, not a
# personal email).
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=
# CONFLUENCE_PARENT_PAGE_ID=       # optional — nest drafts under this page ID
# CONFLUENCE_BASE_URL=             # optional — defaults to postmanlabs.atlassian.net/wiki

# GitHub — fine-grained PAT with Contents:read on Postman-Devrel/devrel-claude-code-skills.
# Lets write-draft fetch the shared blog-write SKILL.md at runtime so prompt updates
# propagate without a redeploy. Required if the skills repo is private.
GITHUB_SKILLS_TOKEN=

# Optional — OpenTelemetry collector endpoint (defaults to localhost:4318)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
